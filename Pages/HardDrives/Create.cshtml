@page
@model CIT195HonorsProject.Pages.HardDrives.CreateModel

        @{
        ViewData["Title"] = "Create";
        }
        
        <h1>Create</h1>
        
    <h4>HardDrive</h4>
    <hr />
    <div class="row">
    <div class="col-md-4">
    <form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="HardDrive.Manufacturer" class="control-label"></label>
                <input asp-for="HardDrive.Manufacturer" class="form-control" aria-required="true"/>
                <span asp-validation-for="HardDrive.Manufacturer" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="HardDrive.CapacityGB" class="control-label"></label>
                <input asp-for="HardDrive.CapacityGB" class="form-control" />
                <span asp-validation-for="HardDrive.CapacityGB" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="HardDrive.IsSolidState" /> @Html.DisplayNameFor(model => model.HardDrive.IsSolidState)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="HardDrive.NodeClusterId" class="control-label"></label>
                <select asp-for="HardDrive.NodeClusterId" class ="form-control" asp-items="ViewBag.NodeClusterId" ></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-success" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
