@page
@model CIT195HonorsProject.Pages.HardDrives.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>HardDrive</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.HardDrive.Manufacturer)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.HardDrive.Manufacturer)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.HardDrive.CapacityGB)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.HardDrive.CapacityGB)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.HardDrive.IsSolidState)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.HardDrive.IsSolidState)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.HardDrive.NodeClusters)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.HardDrive.NodeClusters.NodeLocation)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="HardDrive.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-page="./Index">Back to List</a>
    </form>
</div>
